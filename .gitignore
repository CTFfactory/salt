/configure
/aclocal.m4
/config.h.in
/config.cache
/config.guess
/config.log
/config.status
/config.sub
/config.h
/stamp-h1
/autoscan.log
/autoscan-*.log
/configure.scan
autom4te.cache/

# automake outputs
Makefile
Makefile.in
.deps/
.dirstamp

# build-aux/ — fully populated by autoreconf -fi (AC_CONFIG_AUX_DIR)
build-aux/

